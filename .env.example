PG_DSN=postgresql://qalitas_app:change_me@localhost:5432/Qalitas_ai
# Optionnel: si A4 utilise une base pgvector dédiée, renseigner PG_DSN_A4.
# Sinon, laisser vide et A4 utilisera PG_DSN.
# PG_DSN_A4=postgresql://qalitas_app:change_me@localhost:5432/Qalitas_ai

AUTH_DEFAULT_TENANT=tenant_demo
AUTH_BOOTSTRAP_ENABLED=1
AUTH_BOOTSTRAP_TENANT=tenant_demo
AUTH_BOOTSTRAP_SUPER_ADMIN_USERNAME=superadmin@example.local
AUTH_BOOTSTRAP_SUPER_ADMIN_PASSWORD=change_me
AUTH_BOOTSTRAP_SUPER_ADMIN_DISPLAY_NAME=Super Admin Plateforme
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin@example.local
AUTH_BOOTSTRAP_ADMIN_PASSWORD=change_me
AUTH_BOOTSTRAP_ADMIN_DISPLAY_NAME=Admin Plateforme
AUTH_BOOTSTRAP_ANALYSTE_USERNAME=analyste@example.local
AUTH_BOOTSTRAP_ANALYSTE_PASSWORD=change_me
AUTH_BOOTSTRAP_ANALYSTE_DISPLAY_NAME=Analyste Conformite
AUTH_BOOTSTRAP_AUDITEUR_USERNAME=auditeur@example.local
AUTH_BOOTSTRAP_AUDITEUR_PASSWORD=change_me
AUTH_BOOTSTRAP_AUDITEUR_DISPLAY_NAME=Auditeur Interne

PRIMARY_LLM_PROVIDER=openai
PRIMARY_MODEL=gpt-4.1-mini-2025-04-14

FALLBACK_LLM_PROVIDER=gemini
FALLBACK_MODEL=gemini-2.5-flash

OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key

LLM_TEMPERATURE=0
LLM_MAX_OUTPUT_TOKENS=2048
LLM_PRIMARY_MAX_RETRIES=1
LLM_FALLBACK_MAX_RETRIES=1
LLM_CACHE_POLICY_VERSION=B2.4-2.1.0
LLM_CACHE_LOOKUP_RELAXED_ENABLED=0
LLM_CACHE_WRITE_RELAXED_ALIAS=0
LLM_CACHE_NEGATIVE_ENABLED=0
LLM_CACHE_READ_NEGATIVE_ENABLED=0

LLM_DISABLE_SYSTEM_PROXY=1
LLM_AUTO_BYPASS_BROKEN_LOCAL_PROXY=1
LLM_FAILFAST_PRIMARY_RATE_LIMIT=1
LLM_FAILFAST_FALLBACK_RATE_LIMIT=1
LLM_COOLDOWN_ENABLED=1
LLM_COOLDOWN_MIN_SECONDS=45
LLM_COOLDOWN_MAX_SECONDS=600

# OCR A1 (fallback auto pour PDF illisible)
# Installer recommande: C:\Program Files\Tesseract-OCR
QALITAS_TESSERACT_DIR=C:\Program Files\Tesseract-OCR
# Dossier local conseille (contient fra.traineddata + ara.traineddata)
QALITAS_TESSDATA_DIR=C:\Users\MEGA-PC\Desktop\Qalitas_ai\.tools\tessdata
